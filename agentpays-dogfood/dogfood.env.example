# AgentPays Dogfood — Environment Configuration
#
# Source this file before running dogfood.sh, or set env vars directly:
#   source dogfood.env
#   ./dogfood.sh

# MCP server URL (JSON-RPC endpoint)
# Default: http://localhost:8000/mcp
# For a deployed server: MCP_URL=https://agentpays.1pacent.com/mcp
MCP_URL=http://localhost:8000/mcp

# Transaction log path
LOG_FILE=./dogfood-data/transactions.json

# Transaction value (USDC)
TX_VALUE=0.01

# Wallet addresses (mock defaults)
BUYER_WALLET=0xbuyer-mock-001
SELLER_WALLET=0xseller-mock-001

# ── Rating overrides ──
# Each dimension 1-5. Leave empty for defaults (5/4/5/4/5)
RATING_QUALITY=5
RATING_ACCURACY=4
RATING_SPEED=5
RATING_COMMUNICATION=4
RATING_REHIRE=5

# ── Dry run ──
# Uncomment to print steps without executing MCP calls
# DRY_RUN=1

# ── Discovery filters ──
DISCOVER_QUERY="data processing"
DISCOVER_MAX=20